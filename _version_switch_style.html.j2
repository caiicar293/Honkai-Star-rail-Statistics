  /* ── Version switcher ────────────────────────────────────────────────── */
  .version-switch { position: relative; }
  .version-switch-btn {
    display: inline-flex; align-items: center; gap: 7px; background: var(--panel); border: 1px solid var(--border);
    color: var(--accent); font-family: 'Rajdhani', sans-serif; font-size: 15px; font-weight: 700;
    padding: 8px 12px; border-radius: 6px; cursor: pointer; transition: border-color 0.15s; letter-spacing: 0.03em;
    min-width: 90px; justify-content: space-between;
  }
  .version-switch-btn:hover { border-color: var(--accent); }
  .version-switch-btn svg { transition: transform 0.15s; flex-shrink: 0; }
  .version-switch-panel.open ~ .version-switch-btn svg,
  .version-switch-btn.open svg { transform: rotate(180deg); }
  .version-switch-panel {
    display: none; position: absolute; top: calc(100% + 6px); right: 0; z-index: 30;
    background: var(--panel2); border: 1px solid var(--border2); border-radius: 8px;
    padding: 10px; box-shadow: 0 12px 32px rgba(0,0,0,0.5); min-width: 170px; max-height: 360px; overflow-y: auto;
  }
  .version-switch-panel.open { display: block; }
  .version-switch-panel-title { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.1em; font-family: 'Share Tech Mono', monospace; margin-bottom: 8px; white-space: nowrap; }
  .version-switch-list { display: flex; flex-direction: column; gap: 3px; }
  .version-item {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    background: transparent; border: 1px solid transparent; color: var(--text2);
    font-family: 'Share Tech Mono', monospace; font-size: 12px; font-weight: 600;
    padding: 6px 9px; border-radius: 5px; cursor: pointer; transition: all 0.12s; text-align: left; width: 100%;
  }
  .version-item:hover { background: rgba(56,189,248,0.08); color: var(--accent); }
  .version-item.active { color: var(--accent); border-color: rgba(56,189,248,0.3); background: rgba(56,189,248,0.06); }
  .version-item-tag { font-size: 9px; color: var(--teal, #2dd4bf); text-transform: uppercase; letter-spacing: 0.06em; }
  .version-switch-older-toggle {
    width: 100%; margin-top: 6px; background: none; border: none; border-top: 1px dashed var(--border2);
    color: var(--text3); font-family: 'Share Tech Mono', monospace; font-size: 10.5px; padding: 8px 2px 2px;
    cursor: pointer; text-align: center;
  }
  .version-switch-older-toggle:hover { color: var(--accent); }
  .version-switch-older { display: none; margin-top: 4px; }
  .version-switch-older.open { display: flex; }
  .version-switch-loading { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--text3); padding: 6px 2px; }
