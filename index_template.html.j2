      telemetry insight engine · v<span class="cur-version">{{ version }}</span> · <span id="liveDate"></span>
    </div>
  </footer>

</div>

<script>
  // Dynamic version injected by Jinja
  const VERSION = '{{ version }}';
  document.title = `Telemetry Analytics Hub · v${VERSION}`;

  const dateEl = document.getElementById('liveDate');
  if (dateEl) {
    dateEl.textContent = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function animateIn(el, delay) {
    if (!el) return;
    if (prefersReduced) {
      el.style.opacity = '1';
      el.style.transform = 'none';
      return;
    }
    setTimeout(() => {
      el.style.transition = 'opacity 0.5s ease, transform 0.5s cubic-bezier(0.22,1,0.36,1)';
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, delay);
  }

  animateIn(document.getElementById('heroTitle'),   60);
  animateIn(document.getElementById('versionBadge'), 140);
  animateIn(document.getElementById('heroSub'),      210);
  animateIn(document.getElementById('techStack'), 270);
  animateIn(document.getElementById('charDbCard'), 280);
  animateIn(document.getElementById('tierListCard'), 280); 
  animateIn(document.getElementById('byCostTierListCard'), 280);
  animateIn(document.getElementById('networkGraphsCard'), 280); // Added new animation trigger

  document.querySelectorAll('.card').forEach((card, i) => {
    animateIn(card, 280 + i * 55);
  });
  
  // Ripple effect on click
  document.querySelectorAll('.card').forEach(card => {
    card.addEventListener('click', function(e) {
      const rect   = this.getBoundingClientRect();
      const ripple = document.createElement('span');
      ripple.className = 'ripple';
      ripple.style.left = (e.clientX - rect.left - 30) + 'px';
      ripple.style.top  = (e.clientY - rect.top  - 30) + 'px';
      this.appendChild(ripple);
      ripple.addEventListener('animationend', () => ripple.remove(), { once: true });
    });
  });
  
  // --- HTML5 Canvas Particle System ---
  if (!prefersReduced) {
    const canvas = document.getElementById('particle-canvas');
    const ctx = canvas.getContext('2d');
    let width, height;
    let particles = [];
    
    function resize() {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    class Particle {
      constructor() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        // Small variation in sizes for depth
        this.r = Math.random() * 1.5 + 0.5;
        // Slow horizontal drift
        this.dx = (Math.random() - 0.5) * 0.4;
        // Slow vertical, slight upward drift to simulate floating energy
        this.dy = (Math.random() - 0.5) * 0.4 - 0.2;
        // Semi-transparent base opacity
        this.alpha = Math.random() * 0.4 + 0.1;
      }
      
      update() {
        this.x += this.dx;
        this.y += this.dy;
        
        // Wrap around screen edges
        if (this.x < 0) this.x = width;
        if (this.x > width) this.x = 0;
        if (this.y < 0) this.y = height;
        if (this.y > height) this.y = 0;
      }
      
      draw() {
        // Theme color: Cyan (#38bdf8) mixed with pure white
        ctx.fillStyle = `rgba(56, 189, 248, ${this.alpha})`;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // Initialize 80 particles
    for (let i = 0; i < 80; i++) {
      particles.push(new Particle());
    }

    function animateParticles() {
      ctx.clearRect(0, 0, width, height);
      particles.forEach(p => { 
        p.update(); 
        p.draw(); 
      });
      requestAnimationFrame(animateParticles);
    }
    animateParticles();
  }
</script>
</body>
