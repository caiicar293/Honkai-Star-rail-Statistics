{# ==========================================================================
   network_dashboard_svg.html.j2
   ---------------------------------------------------------------------
   Pure SVG + CSS + vanilla JS network graph — no plotly.js dependency.
   Standalone document (this project has no shared base.html.j2 — every
   *_template.html.j2 is self-contained, matching teams_template.html.j2 etc.)

   Data contract (written by export_network_slice() in network_export.py):
     { "nodes": [{name, x, y, eigenvector, weighted_degree, betweenness}],
       "edges": [{u, v, weight}] }

   Manifest contract (docs/network/network_manifest.json):
     { "<GAME_MODE>": { "<at>-<upto>": { "recent": "<path>", "all": "<path>" } } }

   Rendered to: docs/network/index.html (same directory as the manifest and
   every *.json.br slice), so brotli-wasm is imported via "../vendor/..."
   matching docs/moc/*.html, docs/apoc/*.html, etc.
   ========================================================================== #}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>HSR Team Network — Meta Synergy Graph</title>
<link rel="icon" type="image/jpeg" href="../favicon.jpg"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;800&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #090c14; --bg2: #0d1220;
    --panel: #141c2e; --panel2: #1a2338;
    --border: #1e2d47; --border2: #243552;
    --accent: #38bdf8; --accent2: #7dd3fc;
    --gold: #fbbf24; --teal: #2dd4bf;
    --purple: #a78bfa; --red: #f87171; --green: #4ade80;
    --muted: #4a5d7a;
    --text: #e2eaf6; --text2: #8fa3c0; --text3: #506070;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Exo 2', sans-serif; min-height: 100vh; overflow-x: hidden; }
  body::before {
    content: ''; position: fixed; inset: 0;
    background-image: linear-gradient(rgba(56,189,248,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(56,189,248,0.03) 1px, transparent 1px);
    background-size: 40px 40px; pointer-events: none; z-index: 0;
  }
  .container { position: relative; z-index: 1; max-width: 1700px; margin: 0 auto; padding: 24px; }

  .header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--border); gap: 20px; flex-wrap: wrap; }
  .header-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.25); border-radius: 4px; padding: 3px 10px; font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }
  .header-badge::before { content: '●'; font-size: 7px; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .header h1 { font-family: 'Rajdhani', sans-serif; font-size: 36px; font-weight: 700; letter-spacing: 0.06em; line-height: 1; }
  .header h1 span { color: var(--accent); }
  .header-sub { font-size: 13px; color: var(--text2); margin-top: 5px; font-family: 'Share Tech Mono', monospace; letter-spacing: 0.05em; }

  .controls { display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; align-items: flex-end; }
  .ctrl-group { display: flex; flex-direction: column; gap: 5px; }
  .ctrl-label { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.1em; font-family: 'Share Tech Mono', monospace; }
  select.ctrl-select {
    background: var(--panel); border: 1px solid var(--border); color: var(--text);
    font-family: 'Rajdhani', sans-serif; font-size: 14px; font-weight: 600;
    padding: 7px 10px; border-radius: 5px; cursor: pointer; min-width: 170px;
  }
  select.ctrl-select:focus { outline: none; border-color: var(--accent); }

  .network-wrap { position: relative; background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .network-title { text-align: center; padding: 14px 0 4px; }
  .network-title .main { font-family: 'Rajdhani', sans-serif; font-size: 20px; font-weight: 700; }
  .network-title .subtitle { color: var(--text2); font-size: 12px; font-family: 'Share Tech Mono', monospace; margin-top: 3px; }
  .network-stats { color: var(--text2); font-size: 12px; font-family: 'Share Tech Mono', monospace; margin-top: 6px; }
  .network-stats b { color: var(--accent2); }
  .network-stats .stats-tag { display: inline-block; padding: 1px 9px; border-radius: 3px; background: rgba(56,189,248,0.1); border: 1px solid rgba(56,189,248,0.3); color: var(--accent); font-size: 11px; margin-left: 6px; }

  #network-svg { width: 100%; height: 76vh; display: block; cursor: grab; touch-action: none; }
  #network-svg:active { cursor: grabbing; }

  .edge { stroke-linecap: round; fill: none; pointer-events: none; transition: opacity 0.15s ease; }
  .edge.weak     { stroke: rgba(140,140,150,0.15); stroke-width: 0.6; }
  .edge.light    { stroke: rgba(150,150,160,0.25); stroke-width: 1.0; }
  .edge.moderate { stroke: rgba(160,170,200,0.40); stroke-width: 1.8; }
  .edge.strong   { stroke: rgba(180,200,255,0.65); stroke-width: 3.0; }
  /* Click-to-focus: unrelated edges disappear entirely rather than just fading/blurring */
  .edge.edge-dim { opacity: 0; }
  .edge.edge-highlight { opacity: 0.95; }

  .node-circle { stroke: rgba(0,0,0,0.8); stroke-width: 1.2; cursor: pointer; }
  .node-circle.top3 { stroke: var(--gold); stroke-width: 2.5; }

  .node-label { fill: #fff; font: 700 11px Arial, sans-serif; text-anchor: middle; pointer-events: none; }

  /* Click-to-focus: fade non-neighbor nodes, keep the selected node + neighbors sharp */
  .node-group { transition: opacity 0.2s ease, filter 0.2s ease; }
  .node-group.node-dim { opacity: 0.15; filter: grayscale(70%); }
  .node-group.node-selected .node-circle { stroke: var(--accent2); stroke-width: 3px; }

  .legend-caption { text-align: center; color: var(--text3); font-size: 11px; padding: 8px 0 4px; font-family: 'Share Tech Mono', monospace; }

  .colorbar-wrap { position: absolute; top: 70px; right: 16px; width: 18px; height: 220px; }
  .colorbar-gradient { width: 100%; height: 100%; border-radius: 3px; background: linear-gradient(to top, #0d0887, #7e03a8, #cc4778, #f89441, #f0f921); }
  .colorbar-label { color: var(--text2); font-size: 11px; font-family: 'Share Tech Mono', monospace; position: absolute; right: 24px; white-space: nowrap; }
  .colorbar-label.max { top: -4px; }
  .colorbar-label.min { bottom: -4px; }
  .colorbar-title { position: absolute; top: -26px; right: -2px; font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; white-space: nowrap; }

  #network-tooltip {
    position: absolute; pointer-events: none;
    background: rgba(10,14,24,0.96); border: 1px solid var(--border2); border-radius: 6px;
    padding: 8px 10px; color: var(--text); font-size: 12px; line-height: 1.5;
    max-width: 260px; opacity: 0; transition: opacity 0.1s ease; z-index: 10;
  }

  #network-status { text-align: center; color: var(--text3); font-family: 'Share Tech Mono', monospace; font-size: 12px; padding: 10px 0; }

  /* ── Two-column dashboard: graph + sidebar ────────────────────────── */
  .dashboard-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 340px;
    gap: 18px;
    margin-bottom: 16px;
    align-items: stretch;
  }
  .dashboard-grid .left-col { display: flex; flex-direction: column; gap: 6px; min-width: 0; }

  /* ── Sidebar: search, threshold slider, sorted chart ─────────────── */
  .sidebar {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px;
    display: flex; flex-direction: column; gap: 16px;
    min-height: 0;
  }
  .sidebar-section { display: flex; flex-direction: column; gap: 8px; min-height: 0; }
  .sidebar-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 12px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--accent2);
  }

  /* Search input */
  .search-input {
    background: var(--panel); border: 1px solid var(--border); color: var(--text);
    font-family: 'Exo 2', sans-serif; font-size: 13px; font-weight: 400;
    padding: 8px 10px; border-radius: 5px; width: 100%; outline: none;
    transition: border-color 0.15s ease;
  }
  .search-input::placeholder { color: var(--text3); }
  .search-input:focus { border-color: var(--accent); }
  .search-meta { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--text3); }

  /* Range slider */
  .range-row { display: flex; justify-content: space-between; align-items: center; font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--text2); }
  .range-row .range-current { color: var(--accent2); font-weight: 600; }
  .range-slider {
    -webkit-appearance: none; appearance: none; width: 100%; height: 4px;
    background: var(--border); border-radius: 2px; outline: none; cursor: pointer;
  }
  .range-slider::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none; width: 14px; height: 14px;
    background: var(--accent); border: 2px solid var(--bg);
    border-radius: 50%; cursor: pointer; margin-top: -5px;
    box-shadow: 0 0 8px rgba(56,189,248,0.4);
  }
  .range-slider::-moz-range-thumb {
    width: 14px; height: 14px; background: var(--accent);
    border: 2px solid var(--bg); border-radius: 50%; cursor: pointer;
    box-shadow: 0 0 8px rgba(56,189,248,0.4);
  }

  /* Sorted total-synergy-weight chart */
  .chart-container {
    flex: 1; min-height: 0; overflow-y: auto;
    display: flex; flex-direction: column; gap: 3px;
    padding-right: 4px;
  }
  .chart-row {
    display: grid; grid-template-columns: 110px 1fr 46px;
    gap: 8px; align-items: center; cursor: pointer;
    padding: 5px 7px; border-radius: 4px; border: 1px solid transparent;
    transition: background 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
  }
  .chart-row:hover { background: rgba(56,189,248,0.07); border-color: rgba(56,189,248,0.25); }
  .chart-row .chart-label {
    font-family: 'Exo 2', sans-serif; font-size: 11px; font-weight: 600;
    color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .chart-row .chart-bar-track {
    height: 8px; background: var(--panel); border-radius: 4px; overflow: hidden; position: relative;
  }
  .chart-row .chart-bar-fill {
    height: 100%; border-radius: 4px;
    background: linear-gradient(to right, var(--purple) 0%, var(--accent) 100%);
    transition: width 0.25s ease;
  }
  .chart-row .chart-value {
    font-family: 'Share Tech Mono', monospace; font-size: 10px;
    color: var(--accent2); text-align: right;
  }
  .chart-row.focused { background: rgba(56,189,248,0.15); border-color: var(--accent); }
  .chart-row.focused .chart-label { color: var(--accent2); }
  .chart-row.search-dim, .chart-row.filtered-out { opacity: 0.20; filter: grayscale(80%); }

  /* Filter states on the graph (commute with focus/dim classes) */
  .node-group.filtered-out { display: none; }
  .node-group.search-dim { opacity: 0.12; filter: grayscale(80%); }
  .edge.edge-search-dim { opacity: 0.06; }
  .edge.filtered-out { display: none; }

  /* Responsive: stack columns on narrower viewports */
  @media (max-width: 1024px) {
    .dashboard-grid { grid-template-columns: 1fr; }
    .sidebar { height: auto; }
    .chart-container { max-height: 50vh; }
  }
</style>
</head>
<body>
<div class="container">
  <div class="header">
    <div>
      <div class="header-badge">Meta Intelligence</div>
      <h1>HSR Team <span>Network</span></h1>
      <div class="header-sub">Character synergy graph · centrality-weighted</div>
    </div>
  </div>

  <div class="controls">
    <div class="ctrl-group">
      <label class="ctrl-label" for="mode-select">Game Mode</label>
      <select id="mode-select" class="ctrl-select"><option>Loading…</option></select>
    </div>
    <div class="ctrl-group">
      <label class="ctrl-label" for="eidolon-select">Eidolon Range</label>
      <select id="eidolon-select" class="ctrl-select"><option>—</option></select>
    </div>
    <div class="ctrl-group">
      <label class="ctrl-label" for="recency-select">Meta Window</label>
      <select id="recency-select" class="ctrl-select"><option>—</option></select>
    </div>
    <div class="ctrl-group">
      <label class="ctrl-label" for="metric-select">Color By</label>
      <select id="metric-select" class="ctrl-select">
        <option value="eigenvector">Meta Value (Eigenvector)</option>
        <option value="weighted_degree">Synergy Volume (Weighted Degree)</option>
        <option value="betweenness">Versatility (Betweenness)</option>
      </select>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="left-col">
      <div class="network-wrap">
        <div class="network-title">
          <div class="main" id="network-title-main">HSR Team Network</div>
          <div class="subtitle" id="network-title-sub">Loading manifest…</div>
          <div class="network-stats" id="network-stats"></div>
        </div>

        <!-- Increased viewBox to 1200x840 for more spacing; SVG scales automatically -->
        <svg id="network-svg" viewBox="0 0 1200 840" preserveAspectRatio="xMidYMid meet">
          <g id="viewport">
            <defs id="node-defs"></defs>
            <g id="edges-layer"></g>
            <g id="nodes-layer"></g>
          </g>
        </svg>

        <div class="colorbar-wrap">
          <div class="colorbar-title" id="colorbar-title">Eigenvector</div>
          <div class="colorbar-gradient"></div>
          <div class="colorbar-label max" id="colorbar-max">1.0</div>
          <div class="colorbar-label min" id="colorbar-min">0.0</div>
        </div>

        <div id="network-tooltip"></div>
      </div>

      <div class="legend-caption">
        Node size &amp; color = selected metric · Gold ring = top 3 · Edge thickness = synergy strength · Scroll or pinch to zoom, drag or swipe to pan · Click a character to isolate its synergies · while focused, hover any character to see its synergy rank vs the focused one, click empty space to clear
      </div>
    </div>

    <aside class="sidebar" aria-label="Network filters and analysis">
      <div class="sidebar-section">
        <div class="sidebar-title">Search Characters</div>
        <input type="text" id="search-input" class="search-input" placeholder="Type a name…" autocomplete="off" spellcheck="false"/>
        <div class="search-meta" id="search-meta"></div>
      </div>

      <div class="sidebar-section">
        <div class="sidebar-title">Min Weighted Degree</div>
        <div class="range-row">
          <span>Threshold</span>
          <span class="range-current" id="range-current">0</span>
        </div>
        <input type="range" id="threshold-slider" class="range-slider" min="0" max="100" step="1" value="0"/>
        <div class="range-row">
          <span>0</span>
          <span id="range-max">100</span>
        </div>
      </div>

      <div class="sidebar-section" style="flex: 1; min-height: 0;">
        <div class="sidebar-title">Top 25 — Total Synergy Weight</div>
        <div id="chart-container" class="chart-container"></div>
      </div>
    </aside>
  </div>

  <div id="network-status" aria-live="polite"></div>
</div>

<script type="module">
  // ── Brotli decompression — identical pattern to every other dashboard on
  //    the site (see teams_template.html.j2 / duos_template.html.j2 etc.) ──
  let _brotliPromise = null;
  function getBrotli() {
    if (!_brotliPromise) {
      _brotliPromise = import("../vendor/brotli-wasm/index.web.js").then(m => m.default);
    }
    return _brotliPromise;
  }

  async function loadCompressedJson(filename) {
    const response = await fetch(filename);
    if (!response.ok) throw new Error('Failed to fetch data: ' + filename);
    const buffer = await response.arrayBuffer();
    const brotli = await getBrotli();
    const decompressed = brotli.decompress(new Uint8Array(buffer));
    return JSON.parse(new TextDecoder().decode(decompressed));
  }

  // ── Mode labels — keyed to match network_manifest.json exactly ──
  const MODE_LABELS = {
    MOC: "Memory of Chaos",
    APOC: "Apocalyptic Shadow",
    PURE_FICTION: "Pure Fiction",
    ANOMALY_F0: "Anomaly Arbitration — Floor 0",
    ANOMALY_F4: "Anomaly Arbitration — Floor 4",
  };
  const MODE_ORDER = ["MOC", "APOC", "PURE_FICTION", "ANOMALY_F0", "ANOMALY_F4"];

  function eidolonLabel(key) {
    const [at, upto] = key.split("-");
    return at === upto ? `E${at} only` : `E${at} – E${upto}`;
  }
  function eidolonSortKey(key) {
    const [at, upto] = key.split("-").map(Number);
    return at * 100 + upto;
  }

  const modeSelect = document.getElementById("mode-select");
  const eidolonSelect = document.getElementById("eidolon-select");
  const recencySelect = document.getElementById("recency-select");
  const metricSelect = document.getElementById("metric-select");
  const statusEl = document.getElementById("network-status");

  const svg = document.getElementById("network-svg");
  const viewport = document.getElementById("viewport");
  const defsLayer = document.getElementById("node-defs");
  const edgesLayer = document.getElementById("edges-layer");
  const nodesLayer = document.getElementById("nodes-layer");
  const tooltip = document.getElementById("network-tooltip");

  // ── Character icons — same injection pattern as Generate_Dashboards.py /
  //    teams_template.html.j2: icons_json + path_prefix come from Jinja
  //    context (see generate_network_dashboard.py). Falls back to an empty
  //    map so the page still renders (as plain colored circles) if the
  //    icons file wasn't wired up.
  const ICONS = {{ icons_json | default('{}') }};
  const ICON_PATH_PREFIX = "{{ path_prefix | default('../') }}";

  function lookupIconUrl(name) {
    let url = ICONS[name];
    if (!url) url = ICONS[name.replace(/\s+LV\.\d+$/, '').trim()];
    if (!url) return null;
    if (!url.startsWith('http')) url = ICON_PATH_PREFIX + url;
    return url;
  }

  // ── Layout constants ──
  const VB_W = 8000, VB_H = 8000, PAD = 30;
  // Spread factor: >1 pushes nodes apart; adjust to taste (1.6 works well)
  const SPREAD_FACTOR = 1.0;

  let manifest = null;
  let currentSlice = null;
  // Store ranks for the current metric to show in tooltip
  let currentRankMap = new Map(); // node name -> rank (1-indexed)
  // Click-to-focus state: character name currently isolated, or null
  let selectedNode = null;
  // Map of neighborName -> {rank, total, weight} vs the currently selectedNode,
  // ranked by synergy edge weight (1 = strongest link). Recomputed whenever
  // selectedNode changes — see toggleFocus()/clearFocus().
  let focusRankMap = new Map();

  // ── Sidebar filter state (search + min weighted-degree threshold) ──
  // searchFilter:    substring entered in the search box (case-insensitive)
  // minWeightedDegree: numeric floor; nodes below this are hidden from the
  //                    graph (and dimmed in the chart). 0 = show everything.
  // The slider's max bound is recomputed per slice inside render() — see
  // the `sliderMax` block there.
  let searchFilter = "";
  let minWeightedDegree = 0;
  // Highest weighted_degree in the current slice — drives the threshold
  // slider's max bound. Declared here (not just assigned in render()) so
  // the assignment doesn't throw a ReferenceError in this module's strict
  // mode, which was previously aborting render() before the chart/slider
  // wiring below it ever ran.
  let currentMaxDegree = 0;
  // Tooltip perf state — see showTooltip()/scheduleTooltip() below
  let lastHoverName = null;
  let wrapRect = null;
  function updateWrapRect() { wrapRect = svg.parentElement.getBoundingClientRect(); }
  updateWrapRect();
  window.addEventListener("resize", updateWrapRect);

  // Manifest paths are written repo-relative (e.g. "docs/network/moc_recent_e0-6.json.br")
  // by network_export.py, but this page and every slice file live in the same
  // directory — so resolve to just the basename rather than assuming the
  // stored path is fetchable as-is from wherever the page happens to be served.
  function resolveFetchPath(manifestPath) {
    return manifestPath.split("/").pop();
  }

  async function loadManifest() {
    const res = await fetch("network_manifest.json");
    manifest = await res.json();
  }

  function populateModeSelect() {
    const present = MODE_ORDER.filter(k => manifest[k]);
    modeSelect.innerHTML = present.map(k => `<option value="${k}">${MODE_LABELS[k] || k}</option>`).join("");
  }

  function populateEidolonSelect(mode) {
    const keys = Object.keys(manifest[mode] || {}).sort((a, b) => eidolonSortKey(a) - eidolonSortKey(b));
    eidolonSelect.innerHTML = keys.map(k => `<option value="${k}">${eidolonLabel(k)}</option>`).join("");
  }

  function populateRecencySelect(mode, eidolonKey) {
    const entry = manifest[mode]?.[eidolonKey] || {};
    const order = ["recent", "all"].filter(r => entry[r]);
    const labels = { recent: "Most Recent 3 Versions", all: "All Versions" };
    recencySelect.innerHTML = order.map(r => `<option value="${r}">${labels[r]}</option>`).join("");
  }

  // ── Layout mapping with spread factor ──
  function toScreen(x, y, bounds) {
    const nx = (x - bounds.minX) / (bounds.maxX - bounds.minX || 1);
    const ny = (y - bounds.minY) / (bounds.maxY - bounds.minY || 1);
    const sx = 0.5 + (nx - 0.5) * SPREAD_FACTOR;
    const sy = 0.5 + (ny - 0.5) * SPREAD_FACTOR;
    const cx = Math.max(0, Math.min(1, sx));
    const cy = Math.max(0, Math.min(1, sy));
    const screenX = PAD + cx * (VB_W - 2 * PAD);
    const screenY = PAD + cy * (VB_H - 2 * PAD);
    return [screenX, screenY];
  }

  function computeBounds(nodes) {
    const xs = nodes.map(n => n.x), ys = nodes.map(n => n.y);
    return { minX: Math.min(...xs), maxX: Math.max(...xs), minY: Math.min(...ys), maxY: Math.max(...ys) };
  }
  function plasmaColor(t) {
    const stops = [[13, 8, 135], [126, 3, 168], [204, 71, 120], [248, 148, 65], [240, 249, 33]];
    const scaled = Math.max(0, Math.min(1, t)) * (stops.length - 1);
    const i = Math.floor(scaled);
    const frac = scaled - i;
    const a = stops[i], b = stops[Math.min(i + 1, stops.length - 1)];
    const c = a.map((v, k) => Math.round(v + (b[k] - v) * frac));
    return `rgb(${c[0]},${c[1]},${c[2]})`;
  }
  function edgeBand(w, quartiles) {
    if (w <= quartiles[0]) return "weak";
    if (w <= quartiles[1]) return "light";
    if (w <= quartiles[2]) return "moderate";
    return "strong";
  }

  const METRIC_LABELS = {
    eigenvector: "Meta Value (Eigenvector)",
    weighted_degree: "Synergy Volume (Weighted Degree)",
    betweenness: "Versatility (Betweenness)",
  };

  function render(slice, metric) {
    edgesLayer.innerHTML = "";
    nodesLayer.innerHTML = "";
    defsLayer.innerHTML = "";
    lastHoverName = null; // metric/rank data is about to change, don't let a stale tooltip persist across it

    const bounds = computeBounds(slice.nodes);
    const screenPos = new Map(slice.nodes.map(n => [n.name, toScreen(n.x, n.y, bounds)]));

    const weights = slice.edges.map(e => e.weight).sort((a, b) => a - b);
    const q = p => weights[Math.floor(p * (weights.length - 1))] ?? 0;
    const quartiles = [q(0.25), q(0.5), q(0.75)];

    slice.edges.forEach(e => {
      const posU = screenPos.get(e.u), posV = screenPos.get(e.v);
      if (!posU || !posV) return;
      const [x1, y1] = posU, [x2, y2] = posV;
      const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
      line.setAttribute("x1", x1); line.setAttribute("y1", y1);
      line.setAttribute("x2", x2); line.setAttribute("y2", y2);
      line.setAttribute("class", `edge ${edgeBand(e.weight, quartiles)}`);
      line.dataset.u = e.u;
      line.dataset.v = e.v;
      edgesLayer.appendChild(line);
    });

    const vals = slice.nodes.map(n => n[metric] ?? 0);
    const maxVal = Math.max(...vals, 1e-9);
    const minVal = Math.min(...vals, 0);
    const sortedVals = [...vals].sort((a, b) => b - a);
    const labelThreshold = sortedVals[Math.floor(sortedVals.length * 0.25)] ?? 0;
    const top3 = new Set([...vals.keys()].sort((a, b) => vals[b] - vals[a]).slice(0, 3));

    // Compute ranks for the current metric (1 = highest)
    const rankMap = new Map();
    const sortedIndices = [...vals.keys()].sort((a, b) => vals[b] - vals[a]);
    sortedIndices.forEach((idx, pos) => {
      const name = slice.nodes[idx].name;
      rankMap.set(name, pos + 1);
    });
    currentRankMap = rankMap; // store for tooltip

    document.getElementById("colorbar-title").textContent = METRIC_LABELS[metric];
    document.getElementById("colorbar-max").textContent = maxVal.toFixed(3);
    document.getElementById("colorbar-min").textContent = minVal.toFixed(3);

    const SVGNS = "http://www.w3.org/2000/svg";

    slice.nodes.forEach((n, i) => {
      const [cx, cy] = screenPos.get(n.name);
      const v = vals[i];
      const t = (v - minVal) / (maxVal - minVal || 1);
      const r = 20 + t * 80;

      const g = document.createElementNS(SVGNS, "g");
      g.classList.add("node-group");
      g.dataset.name = n.name;

      // Backing circle — colored by the active metric. Always drawn first:
      // it's the fallback if the icon 404s, and it's what actually receives
      // hover/click events (the icon image sits on top with pointer-events: none).
      const circle = document.createElementNS(SVGNS, "circle");
      circle.setAttribute("cx", cx);
      circle.setAttribute("cy", cy);
      circle.setAttribute("r", r);
      circle.setAttribute("fill", plasmaColor(t));
      circle.setAttribute("class", `node-circle${top3.has(i) ? " top3" : ""}`);
      circle.dataset.name = n.name;
      circle.addEventListener("mousemove", (ev) => scheduleTooltip(ev, n));
      circle.addEventListener("mouseleave", hideTooltip);
      circle.addEventListener("click", (ev) => {
        ev.stopPropagation();
        toggleFocus(n.name);
      });
      g.appendChild(circle);

      const iconUrl = lookupIconUrl(n.name);
      if (iconUrl) {
        // Circular clip so the (usually square) icon art fills the node
        // without spilling past its border.
        const clipId = `nodeclip-${i}`;
        const clipPath = document.createElementNS(SVGNS, "clipPath");
        clipPath.setAttribute("id", clipId);
        const clipCircle = document.createElementNS(SVGNS, "circle");
        clipCircle.setAttribute("cx", cx);
        clipCircle.setAttribute("cy", cy);
        clipCircle.setAttribute("r", Math.max(0, r - 1.5));
        clipPath.appendChild(clipCircle);
        defsLayer.appendChild(clipPath);

        const image = document.createElementNS(SVGNS, "image");
        image.setAttribute("x", cx - r);
        image.setAttribute("y", cy - r);
        image.setAttribute("width", r * 2);
        image.setAttribute("height", r * 2);
        image.setAttribute("preserveAspectRatio", "xMidYMid slice");
        image.setAttribute("clip-path", `url(#${clipId})`);
        image.setAttribute("href", iconUrl);
        image.setAttributeNS("http://www.w3.org/1999/xlink", "href", iconUrl); // older-browser fallback
        image.style.pointerEvents = "none";
        // If the icon 404s, hide it so the colored metric circle underneath shows through.
        image.addEventListener("error", () => { image.style.display = "none"; });
        g.appendChild(image);

        // Ring drawn on top of the icon so the metric-color / gold-top3 border
        // still reads clearly around the artwork.
        const ring = document.createElementNS(SVGNS, "circle");
        ring.setAttribute("cx", cx);
        ring.setAttribute("cy", cy);
        ring.setAttribute("r", r);
        ring.setAttribute("fill", "none");
        ring.setAttribute("class", `node-circle${top3.has(i) ? " top3" : ""}`);
        ring.style.pointerEvents = "none";
        g.appendChild(ring);
      }

      if (v >= labelThreshold) {
        const label = document.createElementNS(SVGNS, "text");
        label.setAttribute("x", cx);
        label.setAttribute("y", cy - r - 4);
        label.setAttribute("class", "node-label");
        label.textContent = n.name;
        g.appendChild(label);
      }
      nodesLayer.appendChild(g);
    });

    const mode = modeSelect.value;
    const eidolonKey = eidolonSelect.value;
    const recencyLabel = recencySelect.value === "recent" ? "Recent Meta" : "All Versions";
    document.getElementById("network-title-main").textContent =
      `HSR Team Network — ${MODE_LABELS[mode] || mode}`;
    document.getElementById("network-title-sub").textContent =
      `${eidolonLabel(eidolonKey)} · ${recencyLabel} · ${slice.nodes.length} characters · ${slice.edges.length} synergy links`;

    renderGraphStats(slice);

    // ── Sidebar sync: slider bounds, chart, then filters ──
    // Slider max follows whoever has the highest weighted_degree in this
    // slice so dragging always spans the full data range; reset the
    // threshold to 0 if the previous value is now off-scale. Use a single
    // ceiled value for both the UI bound and the reset comparison so the two
    // can't disagree (e.g. wdMax=12.4 with a persisted threshold of 13 would
    // otherwise falsely trip the reset because 13 > 12.4 but the slider
    // still shows max=13).
    const wdMax = slice.nodes.length ? Math.max(...slice.nodes.map(n => n.weighted_degree ?? 0)) : 0;
    const sliderMax = Math.max(1, Math.ceil(wdMax)); // never 0 so <input range max=0> doesn't lock up
    currentMaxDegree = sliderMax;
    thresholdSlider.max = sliderMax;
    rangeMax.textContent = String(sliderMax);
    if (minWeightedDegree > sliderMax) {
      minWeightedDegree = 0;
      thresholdSlider.value = 0;
      rangeCurrent.textContent = "0";
    }

    renderWeightChart(slice);
    applyFilters();

    // Re-apply any existing click-to-focus selection to the freshly built
    // elements (render() rebuilds the whole DOM each call, so this state
    // doesn't survive on its own).
    applyFocusStyles();
  }

  // ── Graph-level meta-diversity stats: density + average degree ──
  // These describe the WHOLE graph, not any one character, so they're
  // computed once per render rather than per-node like the coloring metrics.
  //
  //   Density     = 2E / (V(V-1))   — fraction of all possible character
  //                                    pairings that actually see play
  //                                    together, from 0 (no overlap at all)
  //                                    to 1 (every character teams with
  //                                    every other character).
  //   Avg Degree  = 2E / V          — the typical number of distinct
  //                                    synergy partners a character has.
  //
  // Read together: high density + high avg degree → a wide, interconnected
  // meta where lots of characters see varied pairings (diverse). Low values
  // on both → a small clique of characters get played with each other and
  // little else (restricted/narrow meta).
  function renderGraphStats(slice) {
    const V = slice.nodes.length;
    const E = slice.edges.length;
    const density = V > 1 ? (2 * E) / (V * (V - 1)) : 0;
    const avgDegree = V > 0 ? (2 * E) / V : 0;

    // Rule-of-thumb bands, not a formal statistical threshold — tune these
    // if they don't match how the numbers actually look across your slices.
    let diversityTag;
    if (density >= 0.70) diversityTag = "Diverse Meta";
    else if (density >= 0.50) diversityTag = "Moderate Meta";
    else diversityTag = "Restricted Meta";

    const statsEl = document.getElementById("network-stats");
    if (statsEl) {
      statsEl.innerHTML =
        `Density: <b>${density.toFixed(3)}</b> · ` +
        `Avg Degree: <b>${avgDegree.toFixed(2)}</b>` +
        `<span class="stats-tag">${diversityTag}</span>`;
    }
  }

  // ── Click-to-focus: isolate a node's direct neighbors, hide everything else ──
  // Sidebar references — held once instead of re-querying on every keystroke.
  const searchInput = document.getElementById("search-input");
  const searchMeta = document.getElementById("search-meta");
  const thresholdSlider = document.getElementById("threshold-slider");
  const rangeCurrent = document.getElementById("range-current");
  const rangeMax = document.getElementById("range-max");
  const chartContainer = document.getElementById("chart-container");

  // ── Sorted "total synergy weight per node" chart (sidebar) ──
  // Reads weighted_degree straight off the slice (it IS the sum of edge
  // weights touching each node on the server side — same field the tooltip
  // and node sizing already use), so the chart and the graph can't disagree.
  function renderWeightChart(slice) {
    const entries = slice.nodes
      .map(n => ({ name: n.name, total: n.weighted_degree ?? 0 }))
      .sort((a, b) => b.total - a.total)
      .slice(0, 25);
    const maxTotal = entries.length ? entries[0].total : 1;
    chartContainer.innerHTML = entries.map(e => {
      const pct = maxTotal > 0 ? (e.total / maxTotal) * 100 : 0;
      const safeName = e.name.replace(/"/g, '&quot;');
      return `<div class="chart-row" data-name="${safeName}">` +
        `<span class="chart-label" title="${safeName}">${e.name}</span>` +
        `<div class="chart-bar-track"><div class="chart-bar-fill" style="width: ${pct.toFixed(1)}%"></div></div>` +
        `<span class="chart-value">${e.total.toFixed(1)}</span>` +
        `</div>`;
    }).join("");
    // Wire each row to the same toggle used by the graph — keeps focus state
    // in one place so clicks anywhere (graph node ↔ chart row) commute.
    chartContainer.querySelectorAll(".chart-row").forEach(row => {
      row.addEventListener("click", () => {
        const targetName = row.dataset.name;
        if (targetName) toggleFocus(targetName);
      });
    });
  }

  // ── Apply search + threshold filters across graph AND chart ──
  // Designed to commute cleanly with the existing applyFocusStyles() output:
  //   - .filtered-out  -> display:none (graph) / dimmed (chart). Wins.
  //   - .search-dim    -> very transparent. Skipped on focus-relevant nodes
  //                       AND on edges connected to the focus character, so
  //                       clicking a focus target mid-search doesn't make
  //                       its ring go invisible.
  function applyFilters() {
    if (!currentSlice) return;
    const term = searchFilter.trim().toLowerCase();
    const queryActive = term.length > 0;

    // Per-node status cache — one pass over currentSlice.nodes, then every
    // DOM read below just looks up from this Map.
    const status = new Map();
    currentSlice.nodes.forEach(n => {
      const isFocused = selectedNode === n.name;
      const focusRelevant = isFocused || focusRankMap.has(n.name);
      // Focused character is exempt from threshold filter so the focus state
      // stays visible if the user drags the slider past themselves.
      const below = !isFocused && (n.weighted_degree ?? 0) < minWeightedDegree;
      const matchesSearch = !queryActive || n.name.toLowerCase().includes(term);
      status.set(n.name, { below, matchesSearch, focusRelevant });
    });

    // SVG nodes: hide if below threshold; else dim on search miss UNLESS
    // the node is focus-relevant.
    nodesLayer.querySelectorAll(".node-group").forEach(el => {
      const s = status.get(el.dataset.name);
      if (!s) return;
      if (s.below) {
        el.classList.add("filtered-out");
        el.classList.remove("search-dim");
        return;
      }
      el.classList.remove("filtered-out");
      el.classList.toggle("search-dim", !s.matchesSearch && !s.focusRelevant);
    });

    // SVG edges: hide if either endpoint is below threshold; otherwise
    // dim when either endpoint is a search miss, except for edges touching
    // the focused character (applyFocusStyles() already handles those).
    edgesLayer.querySelectorAll(".edge").forEach(el => {
      const u = status.get(el.dataset.u), v = status.get(el.dataset.v);
      if (!u || !v) return;
      if (u.below || v.below) {
        el.classList.add("filtered-out");
        el.classList.remove("edge-search-dim");
        return;
      }
      el.classList.remove("filtered-out");
      const isFocusEdge = selectedNode !== null &&
        (el.dataset.u === selectedNode || el.dataset.v === selectedNode);
      const searchDim = !u.matchesSearch || !v.matchesSearch;
      el.classList.toggle("edge-search-dim", searchDim && !isFocusEdge);
    });

    // Chart rows: mirror graph visibility logic + flag currently-focused row.
    chartContainer.querySelectorAll(".chart-row").forEach(el => {
      const s = status.get(el.dataset.name);
      if (!s) return;
      el.classList.toggle("filtered-out", s.below);
      if (s.below) {
        el.classList.remove("search-dim");
      } else {
        el.classList.toggle("search-dim", !s.matchesSearch);
      }
      el.classList.toggle("focused", el.dataset.name === selectedNode);
    });

    // Live "N matches" readout under the search box.
    if (searchMeta) {
      if (!queryActive) { searchMeta.textContent = ""; }
      else {
        const count = [...status.values()].filter(s => !s.below && s.matchesSearch).length;
        searchMeta.textContent = `${count} match${count === 1 ? "" : "es"}`;
      }
    }
  }

  function computeFocusRanks(name) {
    // Ranks every direct neighbor of `name` by synergy edge weight (1 = strongest).
    const map = new Map();
    if (!currentSlice) return map;
    const links = [];
    currentSlice.edges.forEach(e => {
      if (e.u === name) links.push({ neighbor: e.v, weight: e.weight });
      else if (e.v === name) links.push({ neighbor: e.u, weight: e.weight });
    });
    links.sort((a, b) => b.weight - a.weight);
    links.forEach((l, i) => map.set(l.neighbor, { rank: i + 1, total: links.length, weight: l.weight }));
    return map;
  }

  function applyFocusStyles() {
    const edgeEls = edgesLayer.querySelectorAll("line");
    const nodeEls = nodesLayer.querySelectorAll(".node-group");

    if (!selectedNode) {
      edgeEls.forEach(el => el.classList.remove("edge-dim", "edge-highlight"));
      nodeEls.forEach(el => el.classList.remove("node-dim", "node-selected"));
      return;
    }

    edgeEls.forEach(el => {
      const connected = el.dataset.u === selectedNode || el.dataset.v === selectedNode;
      el.classList.toggle("edge-highlight", connected);
      el.classList.toggle("edge-dim", !connected); // unrelated edges vanish entirely (opacity: 0)
    });

    nodeEls.forEach(el => {
      const name = el.dataset.name;
      const isSelected = name === selectedNode;
      const isNeighbor = focusRankMap.has(name);
      el.classList.toggle("node-selected", isSelected);
      el.classList.toggle("node-dim", !isSelected && !isNeighbor);
    });
  }

  function toggleFocus(name) {
    selectedNode = (selectedNode === name) ? null : name;
    focusRankMap = selectedNode ? computeFocusRanks(selectedNode) : new Map();
    lastHoverName = null; // tooltip content now depends on focus state — force a rebuild on the next hover
    applyFocusStyles();
    // applyFilters also re-checks focus-relevant exemptions: e.g. the chart
    // row's .focused class, and keeps a search-dimmed focused character from
    // hiding behind its own ring (search-dim wins over node-dim in source order).
    applyFilters();
  }

  function clearFocus() {
    if (selectedNode !== null) {
      selectedNode = null;
      focusRankMap = new Map();
      lastHoverName = null;
      applyFocusStyles();
      applyFilters();
    }
  }

  function showTooltip(ev, node) {
    // Only rebuild the tooltip's HTML when we've actually moved onto a
    // different node — not on every pixel of mouse movement within the
    // same one. Position still updates every call (cheap: no layout read).
    if (node.name !== lastHoverName) {
      lastHoverName = node.name;
      const metric = metricSelect.value;
      const rank = currentRankMap.get(node.name) || '?';
      const metricLabel = METRIC_LABELS[metric];

      // While a character is focused (click-to-isolate), show how this
      // hovered character relates to it: its synergy rank if they're
      // directly linked, or an explicit "no direct synergy" note otherwise.
      let focusSection = "";
      if (selectedNode) {
        if (node.name === selectedNode) {
          focusSection = `<br>―――――――――――――――<br><b>★ Focused character</b>`;
        } else if (focusRankMap.has(node.name)) {
          const info = focusRankMap.get(node.name);
          focusSection = `<br>―――――――――――――――<br>` +
            `Synergy vs ${selectedNode}: #${info.rank} of ${info.total}<br>` +
            `Link weight: ${info.weight.toFixed(2)}`;
        } else {
          focusSection = `<br>―――――――――――――――<br>No direct synergy with ${selectedNode}`;
        }
      }

      tooltip.innerHTML =
        `<b>${node.name}</b><br>` +
        `Rank (${metricLabel}): #${rank}<br>` +
        `―――――――――――――――<br>` +
        `Eigenvector: ${node.eigenvector.toFixed(4)}<br>` +
        `Weighted Degree: ${node.weighted_degree.toFixed(1)}<br>` +
        `Betweenness: ${node.betweenness.toFixed(4)}` +
        focusSection;
    }
    // wrapRect is cached (see updateWrapRect above) instead of read fresh on
    // every mousemove — getBoundingClientRect() forces a synchronous layout,
    // and doing that dozens of times a second while hovering was the main
    // reason clicking felt laggier on desktop than on mobile (touch has no
    // hover state at all, so it never paid this cost).
    if (!wrapRect) updateWrapRect();
    tooltip.style.left = `${ev.clientX - wrapRect.left + 14}px`;
    tooltip.style.top = `${ev.clientY - wrapRect.top + 14}px`;
    tooltip.style.opacity = 1;
  }

  // Coalesce rapid mousemove-driven tooltip updates to at most once per
  // animation frame, so hover work never competes with (and delays) the
  // paint that should be starting the click-to-focus transition.
  let tooltipRAF = null;
  function scheduleTooltip(ev, node) {
    if (tooltipRAF) cancelAnimationFrame(tooltipRAF);
    const clientX = ev.clientX, clientY = ev.clientY; // capture now — the event object may be recycled by the time rAF fires
    tooltipRAF = requestAnimationFrame(() => showTooltip({ clientX, clientY }, node));
  }

  function hideTooltip() {
    tooltip.style.opacity = 0;
    lastHoverName = null;
  }

  // ── Pan + zoom (mouse + touch) ──
  let scale = 1, panX = 0, panY = 0, isDragging = false, lastX = 0, lastY = 0;
  let dragMoved = false, dragStartX = 0, dragStartY = 0;
  const DRAG_CLICK_THRESHOLD = 4; // px — below this, mouseup/touchend counts as a tap, not a pan
  const MIN_SCALE = 0.4, MAX_SCALE = 4;
  function applyTransform() { viewport.setAttribute("transform", `translate(${panX},${panY}) scale(${scale})`); }

  // Mouse: wheel zoom, drag pan
  svg.addEventListener("wheel", (ev) => {
    ev.preventDefault();
    const delta = ev.deltaY > 0 ? 0.9 : 1.1;
    scale = Math.min(Math.max(scale * delta, MIN_SCALE), MAX_SCALE);
    applyTransform();
  }, { passive: false });
  svg.addEventListener("mousedown", (ev) => {
    isDragging = true;
    dragMoved = false;
    dragStartX = ev.clientX; dragStartY = ev.clientY;
    lastX = ev.clientX; lastY = ev.clientY;
  });
  window.addEventListener("mousemove", (ev) => {
    if (!isDragging) return;
    if (Math.hypot(ev.clientX - dragStartX, ev.clientY - dragStartY) > DRAG_CLICK_THRESHOLD) dragMoved = true;
    panX += ev.clientX - lastX; panY += ev.clientY - lastY;
    lastX = ev.clientX; lastY = ev.clientY;
    applyTransform();
  });
  window.addEventListener("mouseup", () => { isDragging = false; });

  // Click empty space (not a node, not the tail end of a drag) to clear the
  // click-to-focus selection. Nodes call stopPropagation() on their own
  // click handler, so this only fires for clicks that land on the SVG
  // background itself.
  svg.addEventListener("click", (ev) => {
    if (dragMoved) { dragMoved = false; return; }
    if (ev.target === svg) clearFocus();
  });

  // Touch: one-finger pan, two-finger pinch-to-zoom.
  // touch-action: none (in CSS above) stops the browser's own scroll/zoom
  // gestures from fighting with these handlers.
  let touchMode = null; // 'pan' | 'pinch'
  let pinchStartDist = 0, pinchStartScale = 1;
  let pinchStartMidX = 0, pinchStartMidY = 0;
  let pinchStartPanX = 0, pinchStartPanY = 0;

  function touchDist(t0, t1) {
    return Math.hypot(t1.clientX - t0.clientX, t1.clientY - t0.clientY);
  }
  function touchMid(t0, t1) {
    return { x: (t0.clientX + t1.clientX) / 2, y: (t0.clientY + t1.clientY) / 2 };
  }

  svg.addEventListener("touchstart", (ev) => {
    if (ev.touches.length === 1) {
      touchMode = "pan";
      dragMoved = false;
      dragStartX = ev.touches[0].clientX;
      dragStartY = ev.touches[0].clientY;
      lastX = ev.touches[0].clientX;
      lastY = ev.touches[0].clientY;
    } else if (ev.touches.length === 2) {
      touchMode = "pinch";
      pinchStartDist = touchDist(ev.touches[0], ev.touches[1]);
      pinchStartScale = scale;
      const mid = touchMid(ev.touches[0], ev.touches[1]);
      pinchStartMidX = mid.x; pinchStartMidY = mid.y;
      pinchStartPanX = panX; pinchStartPanY = panY;
    }
  }, { passive: false });

  svg.addEventListener("touchmove", (ev) => {
    ev.preventDefault();
    if (touchMode === "pan" && ev.touches.length === 1) {
      const t = ev.touches[0];
      if (Math.hypot(t.clientX - dragStartX, t.clientY - dragStartY) > DRAG_CLICK_THRESHOLD) dragMoved = true;
      panX += t.clientX - lastX; panY += t.clientY - lastY;
      lastX = t.clientX; lastY = t.clientY;
      applyTransform();
    } else if (touchMode === "pinch" && ev.touches.length === 2) {
      dragMoved = true; // a pinch is never a tap
      const newDist = touchDist(ev.touches[0], ev.touches[1]);
      scale = Math.min(Math.max(pinchStartScale * (newDist / pinchStartDist), MIN_SCALE), MAX_SCALE);
      const mid = touchMid(ev.touches[0], ev.touches[1]);
      panX = pinchStartPanX + (mid.x - pinchStartMidX);
      panY = pinchStartPanY + (mid.y - pinchStartMidY);
      applyTransform();
    }
  }, { passive: false });

  function touchEnd(ev) {
    if (ev.touches.length === 1) {
      // Dropped from pinch to a single finger — resume panning from here
      touchMode = "pan";
      lastX = ev.touches[0].clientX;
      lastY = ev.touches[0].clientY;
    } else if (ev.touches.length === 0) {
      touchMode = null;
    }
  }
  svg.addEventListener("touchend", touchEnd);
  svg.addEventListener("touchcancel", touchEnd);

  // ── Load orchestration ──
  async function loadCurrentSlice() {
    const mode = modeSelect.value;
    const eidolonKey = eidolonSelect.value;
    const recency = recencySelect.value;
    const manifestPath = manifest[mode]?.[eidolonKey]?.[recency];
    if (!manifestPath) {
      statusEl.textContent = "No precomputed slice for this combination.";
      return;
    }
    statusEl.textContent = "Loading network slice…";
    try {
      currentSlice = await loadCompressedJson(resolveFetchPath(manifestPath));
      selectedNode = null; // a new slice may not contain the previously focused character
      focusRankMap = new Map();
      render(currentSlice, metricSelect.value);
      statusEl.textContent = "";
    } catch (err) {
      console.error("Network slice load error:", err);
      statusEl.textContent = "⚠️ Failed to load data. Check console.";
    }
  }

  metricSelect.addEventListener("change", () => {
    if (currentSlice) render(currentSlice, metricSelect.value);
  });
  modeSelect.addEventListener("change", () => {
    populateEidolonSelect(modeSelect.value);
    populateRecencySelect(modeSelect.value, eidolonSelect.value);
    loadCurrentSlice();
  });
  eidolonSelect.addEventListener("change", () => {
    populateRecencySelect(modeSelect.value, eidolonSelect.value);
    loadCurrentSlice();
  });
  recencySelect.addEventListener("change", loadCurrentSlice);

  // ── Sidebar: search box filters by character name as you type ──
  searchInput.addEventListener("input", (ev) => {
    searchFilter = ev.target.value;
    // Force tooltip to rebuild on the next hover — the search-dim state
    // changes which rank numbers are visually meaningful in the status block.
    lastHoverName = null;
    applyFilters();
  });
  searchInput.addEventListener("keydown", (ev) => {
    if (ev.key === "Escape" && searchInput.value !== "") {
      searchInput.value = "";
      searchFilter = "";
      lastHoverName = null;
      applyFilters();
    }
  });

  // ── Sidebar: threshold slider sets a floor on weighted_degree ──
  // 'input' fires while dragging (live feedback); 'change' fires once on
  // release. We only need the live one — applyFilters() is cheap at this size.
  thresholdSlider.addEventListener("input", (ev) => {
    minWeightedDegree = parseFloat(ev.target.value) || 0;
    rangeCurrent.textContent = String(minWeightedDegree);
    applyFilters();
  });

  (async () => {
    try {
      await loadManifest();
      populateModeSelect();
      populateEidolonSelect(modeSelect.value);
      populateRecencySelect(modeSelect.value, eidolonSelect.value);
      await loadCurrentSlice();
    } catch (err) {
      console.error("Manifest load error:", err);
      statusEl.textContent = "⚠️ Failed to load network manifest. Check console.";
    }
  })();
</script>
</body>
</html>
