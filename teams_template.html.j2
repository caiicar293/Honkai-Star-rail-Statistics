<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{{ mode_label }} {{ version }} — Teams</title>
<link rel="icon" type="image/jpeg" href="../favicon.jpg"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;800&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #090c14; --bg2: #0d1220;
    --panel: #141c2e; --panel2: #1a2338;
    --border: #1e2d47; --border2: #243552;
    --accent: #38bdf8; --accent2: #7dd3fc;
    --gold: #fbbf24; --teal: #2dd4bf;
    --purple: #a78bfa; --red: #f87171; --green: #4ade80;
    --muted: #4a5d7a;
    --text: #e2eaf6; --text2: #8fa3c0; --text3: #506070;
    --dim0: #6366f1; --dim1: #38bdf8; --dim2: #f472b6;
    --dim3: #fb923c; --dim4: #a78bfa;
    --e0: #94a3b8; --e1: #4ade80; --e2: #38bdf8; --e6: #fbbf24;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Exo 2', sans-serif; min-height: 100vh; overflow-x: hidden; }
  body::before {
    content: ''; position: fixed; inset: 0;
    background-image: linear-gradient(rgba(56,189,248,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(56,189,248,0.03) 1px, transparent 1px);
    background-size: 40px 40px; pointer-events: none; z-index: 0;
  }
  .container { position: relative; z-index: 1; max-width: 1700px; margin: 0 auto; padding: 24px; }

  /* HEADER */
  .header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 28px; padding-bottom: 20px; border-bottom: 1px solid var(--border); gap: 20px; flex-wrap: wrap; }
  .header-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.25); border-radius: 4px; padding: 3px 10px; font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 8px; }
  .header-badge::before { content: '●'; font-size: 7px; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .header h1 { font-family: 'Rajdhani', sans-serif; font-size: 36px; font-weight: 700; letter-spacing: 0.06em; line-height: 1; }
  .header h1 span { color: var(--accent); }
  .header-sub { font-size: 13px; color: var(--text2); margin-top: 5px; font-family: 'Share Tech Mono', monospace; letter-spacing: 0.05em; }
  .header-meta { display: flex; gap: 16px; flex-wrap: wrap; align-items: center; }
  .meta-chip { background: var(--panel); border: 1px solid var(--border); border-radius: 6px; padding: 8px 14px; text-align: center; min-width: 90px; }
  .meta-chip .val { font-family: 'Rajdhani', sans-serif; font-size: 22px; font-weight: 700; color: var(--accent); display: block; line-height: 1; }
  .meta-chip .lbl { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 3px; }

  /* CONTROLS */
  .controls { display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; align-items: flex-end; }
  .ctrl-group { display: flex; flex-direction: column; gap: 5px; }
  .ctrl-label { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.1em; font-family: 'Share Tech Mono', monospace; }
  .btn-group { display: flex; gap: 4px; flex-wrap: wrap; }
  .btn-toggle { background: var(--panel); border: 1px solid var(--border); color: var(--text2); font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 600; padding: 5px 11px; border-radius: 5px; cursor: pointer; transition: all 0.15s; letter-spacing: 0.04em; white-space: nowrap; }
  .btn-toggle:hover { border-color: var(--accent); color: var(--accent); }

  .btn-toggle.dim-0.active { background: rgba(99,102,241,0.12);  border-color: var(--dim0); color: var(--dim0); }
  .btn-toggle.dim-1.active { background: rgba(56,189,248,0.12);  border-color: var(--dim1); color: var(--dim1); }
  .btn-toggle.dim-2.active { background: rgba(244,114,182,0.12); border-color: var(--dim2); color: var(--dim2); }
  .btn-toggle.dim-3.active { background: rgba(251,146,60,0.12);  border-color: var(--dim3); color: var(--dim3); }
  .btn-toggle.dim-4.active { background: rgba(167,139,250,0.12); border-color: var(--dim4); color: var(--dim4); }

  .btn-toggle.range.at0.active { border-color: var(--e0); color: var(--e0); background: rgba(148,163,184,0.08); }
  .btn-toggle.range.at1.active { border-color: var(--e1); color: var(--e1); background: rgba(74,222,128,0.07); }
  .btn-toggle.range.at2.active { border-color: var(--e2); color: var(--e2); background: rgba(56,189,248,0.08); }
  .btn-toggle.range.at6.active { border-color: var(--e6); color: var(--e6); background: rgba(251,191,36,0.09); }

  .btn-toggle.sustain-on.active  { background: rgba(74,222,128,0.10); border-color: var(--green); color: var(--green); }
  .btn-toggle.sustain-off.active { background: rgba(248,113,113,0.10); border-color: var(--red);   color: var(--red); }

  .search-wrap { position: relative; min-width: 220px; max-width: 360px; }
  .search-wrap svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text3); pointer-events: none; width:14px; height:14px; }
  #searchInput { width: 100%; background: var(--panel); border: 1px solid var(--border); border-radius: 5px; color: var(--text); font-family: 'Exo 2', sans-serif; font-size: 13px; padding: 7px 12px 7px 32px; outline: none; transition: border-color 0.15s; }
  #searchInput:focus { border-color: var(--accent); }
  #searchInput::placeholder { color: var(--text3); }

  /* Character slot filter panel */
  .slot-panel {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end;
    background: var(--panel); border: 1px solid var(--border); border-radius: 8px;
    padding: 12px 14px; margin-bottom: 16px;
  }
  .slot-panel-title {
    font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 0.1em;
    font-family: 'Share Tech Mono', monospace; width: 100%; margin-bottom: 2px;
  }
  .slot { display: flex; flex-direction: column; gap: 4px; min-width: 160px; flex: 1; }
  .slot-input-row { display: flex; gap: 4px; }
  .slot input[type="text"] {
    flex: 1; background: var(--bg2); border: 1px solid var(--border); border-radius: 5px;
    color: var(--text); font-family: 'Exo 2', sans-serif; font-size: 13px;
    padding: 6px 10px; outline: none; transition: border-color 0.15s, background 0.15s;
  }
  .slot input[type="text"]:focus { border-color: var(--accent); }
  .slot input[type="text"].slot-filled { border-color: var(--accent2); background: rgba(56,189,248,0.06); }
  .slot input[type="text"].slot-exclude.slot-filled { border-color: var(--red); background: rgba(248,113,113,0.06); }
  .slot-mode-btn {
    background: var(--bg2); border: 1px solid var(--border); color: var(--text2);
    font-family: 'Share Tech Mono', monospace; font-size: 11px; font-weight: 700;
    border-radius: 5px; padding: 6px 10px; cursor: pointer; transition: all 0.15s;
    min-width: 36px;
  }
  .slot-mode-btn:hover { border-color: var(--accent); color: var(--accent); }
  .slot-mode-btn.mode-include { color: var(--green); border-color: rgba(74,222,128,0.35); background: rgba(74,222,128,0.06); }
  .slot-mode-btn.mode-exclude { color: var(--red); border-color: rgba(248,113,113,0.35); background: rgba(248,113,113,0.06); }
  .slot-clear-all {
    background: var(--bg2); border: 1px solid var(--border); color: var(--text3);
    font-family: 'Rajdhani', sans-serif; font-size: 12px; font-weight: 600;
    border-radius: 5px; padding: 6px 12px; cursor: pointer; transition: all 0.15s;
    height: 34px; align-self: flex-end;
  }
  .slot-clear-all:hover { border-color: var(--red); color: var(--red); }

  .results-info { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--text3); padding: 4px 0 8px; letter-spacing: 0.06em; }
  .results-info span { color: var(--accent); }

  /* TABLE */
  .table-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; background: var(--panel); box-shadow: 0 4px 40px rgba(0,0,0,0.4); }
  .table-scroll { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead tr { background: var(--panel2); border-bottom: 2px solid var(--border2); }
  th { padding: 11px 12px; text-align: left; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: var(--text3); text-transform: uppercase; white-space: nowrap; cursor: pointer; user-select: none; transition: color 0.15s; }
  th:hover { color: var(--accent); }
  th.sorted { color: var(--accent); }
  th.sorted::after { content: ' ↓'; }
  th.sorted.asc::after { content: ' ↑'; }
  th.num { text-align: right; }
  tbody tr { border-bottom: 1px solid rgba(30,45,71,0.6); transition: background 0.1s; }
  tbody tr:hover { background: rgba(56,189,248,0.04); }
  tbody tr:last-child { border-bottom: none; }
  td { padding: 9px 12px; vertical-align: middle; white-space: nowrap; }
  td.num { text-align: right; }

  .rank-cell { font-family: 'Share Tech Mono', monospace; font-size: 11px; color: var(--text3); text-align: center; min-width: 36px; }
  .rank-cell.top3 { color: var(--gold); font-weight: bold; }

  .dim-badge { display: inline-flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; font-family: 'Rajdhani', sans-serif; font-size: 12px; font-weight: 700; }
  .dim-badge.d0 { background: rgba(99,102,241,0.2);  color: var(--dim0); border: 1px solid rgba(99,102,241,0.4); }
  .dim-badge.d1 { background: rgba(56,189,248,0.15);  color: var(--dim1); border: 1px solid rgba(56,189,248,0.35); }
  .dim-badge.d2 { background: rgba(244,114,182,0.15); color: var(--dim2); border: 1px solid rgba(244,114,182,0.35); }
  .dim-badge.d3 { background: rgba(251,146,60,0.15);  color: var(--dim3); border: 1px solid rgba(251,146,60,0.35); }
  .dim-badge.d4 { background: rgba(167,139,250,0.15); color: var(--dim4); border: 1px solid rgba(167,139,250,0.35); }

  .eid-range-badge { display: inline-flex; align-items: center; border-radius: 4px; padding: 2px 6px; font-family: 'Share Tech Mono', monospace; font-size: 10px; border: 1px solid; }
  .eid-range-badge.exact { font-weight: 700; font-size: 11px; }
  .eid-range-badge.at0 { color: var(--e0); border-color: rgba(148,163,184,0.3); background: rgba(148,163,184,0.06); }
  .eid-range-badge.at1 { color: var(--e1); border-color: rgba(74,222,128,0.3);  background: rgba(74,222,128,0.06); }
  .eid-range-badge.at2 { color: var(--e2); border-color: rgba(56,189,248,0.3);  background: rgba(56,189,248,0.07); }
  .eid-range-badge.at6 { color: var(--e6); border-color: rgba(251,191,36,0.35); background: rgba(251,191,36,0.08); }

  .sustain-pill { display: inline-flex; align-items: center; gap: 4px; border-radius: 4px; padding: 2px 8px; font-family: 'Share Tech Mono', monospace; font-size: 11px; font-weight: 600; border: 1px solid; }
  .sustain-pill.yes { color: var(--green); border-color: rgba(74,222,128,0.35); background: rgba(74,222,128,0.08); }
  .sustain-pill.no  { color: var(--red);   border-color: rgba(248,113,113,0.3);  background: rgba(248,113,113,0.07); }
  .sustain-pill.yes::before { content: '✦'; font-size: 8px; }
  .sustain-pill.no::before  { content: '✕'; font-size: 9px; }

  .team-cell { display: flex; align-items: center; gap: 6px; min-width: 280px; max-width: 500px; }
  .team-icons { display: flex; align-items: center; flex-shrink: 0; }
  .char-icon { width: 30px; height: 30px; border-radius: 50%; border: 1.5px solid var(--border2); object-fit: cover; margin-left: -7px; background: var(--bg2); transition: transform 0.15s; }
  .char-icon:first-child { margin-left: 0; }
  .team-cell:hover .char-icon { transform: scale(1.08); }
  .char-icon-placeholder { width: 30px; height: 30px; border-radius: 50%; background: var(--panel2); border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 9px; color: var(--text3); margin-left: -7px; flex-shrink: 0; }
  .char-icon-placeholder:first-child { margin-left: 0; }
  .team-name { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .rate-bar-wrap { display: flex; align-items: center; gap: 7px; min-width: 120px; }
  .rate-bar-bg { flex: 1; height: 5px; background: var(--bg); border-radius: 3px; overflow: hidden; min-width: 55px; }
  .rate-bar-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--accent), var(--teal)); }
  .rate-val { font-family: 'Share Tech Mono', monospace; font-size: 12px; color: var(--accent2); min-width: 44px; text-align: right; }

  .score-num { font-family: 'Share Tech Mono', monospace; font-size: 12px; color: var(--text2); }
  .score-num.median { color: var(--accent); font-weight: 600; font-size: 13px; }
  .score-num.avg    { color: var(--gold); font-size: 13px; }
  .score-num.maxv   { color: var(--purple); }
  .score-num.std    { color: var(--text3); font-size: 11px; }
  .score-num.samp   { color: var(--text2); }

  .group-sep td { background: var(--bg2); padding: 5px 12px; font-family: 'Share Tech Mono', monospace; font-size: 10px; letter-spacing: 0.15em; text-transform: uppercase; border-bottom: 1px solid var(--border2); }
  .group-label-0 { color: var(--dim0); }
  .group-label-1 { color: var(--dim1); }
  .group-label-2 { color: var(--dim2); }
  .group-label-3 { color: var(--dim3); }
  .group-label-4 { color: var(--dim4); }

  .empty-state { text-align: center; padding: 60px 20px; color: var(--text3); }
  .empty-state .icon { font-size: 40px; margin-bottom: 10px; }
  .empty-state p { font-family: 'Share Tech Mono', monospace; font-size: 13px; }

  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg2); }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--muted); }
</style>
</head>
<body>
<div class="container">

  <div class="header">
    <div class="header-left">
      <div class="header-badge">{{ mode_label }}</div>
      <h1>{{ mode_label }} <span>{{ version }}</span> Teams</h1>
      <div class="header-sub">{{ subtitle }} · ENDGAME ANALYTICS · TEAM COMPOSITION &amp; PERFORMANCE</div>
    </div>
    <div class="header-meta">
      <div class="meta-chip"><span class="val" id="visibleCount">—</span><div class="lbl">Teams</div></div>
      <div class="meta-chip"><span class="val" id="visibleSamples">—</span><div class="lbl">Samples</div></div>
      <div class="meta-chip"><span class="val">{{ version }}</span><div class="lbl">Version</div></div>
    </div>
  </div>

  <div class="controls">

    <div class="ctrl-group">
      <div class="ctrl-label">{{ dim_label }}</div>
      <div class="btn-group" id="dimFilters">
        {% for d in dim_values %}
        <button class="btn-toggle dim-{{ d }} active" data-dim="{{ d }}">{{ dim_btn_label(d) }}</button>
        {% endfor %}
      </div>
    </div>

    <div class="ctrl-group">
      <div class="ctrl-label">Eidolon Range (at → up_to)</div>
      <div class="btn-group" id="eidFilters">
        <button class="btn-toggle range at0 active" data-at="0" data-upto="0">E0</button>
        <button class="btn-toggle range at0 active" data-at="0" data-upto="1">E0→1</button>
        <button class="btn-toggle range at0 active" data-at="0" data-upto="2">E0→2</button>
        <button class="btn-toggle range at0 active" data-at="0" data-upto="6">E0→6</button>
        <button class="btn-toggle range at1 active" data-at="1" data-upto="1">E1</button>
        <button class="btn-toggle range at1 active" data-at="1" data-upto="2">E1→2</button>
        <button class="btn-toggle range at1 active" data-at="1" data-upto="6">E1→6</button>
        <button class="btn-toggle range at2 active" data-at="2" data-upto="2">E2</button>
        <button class="btn-toggle range at2 active" data-at="2" data-upto="6">E2→6</button>
        <button class="btn-toggle range at6 active" data-at="6" data-upto="6">E6</button>
      </div>
    </div>

    <div class="ctrl-group">
      <div class="ctrl-label">Sustain</div>
      <div class="btn-group">
        <button class="btn-toggle sustain-on active"  id="btnSustainOn">✦ Sustain</button>
        <button class="btn-toggle sustain-off active" id="btnSustainOff">✕ No Sustain</button>
      </div>
    </div>

    <div class="ctrl-group" style="flex:1; min-width:220px; max-width:380px;">
      <div class="ctrl-label">Team Search</div>
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input id="searchInput" type="text" placeholder="Search e.g. Dan Heng Imbibitor Lunae…"/>
      </div>
    </div>

  </div>

  <!-- Character slot include/exclude panel -->
  <div class="slot-panel">
    <div class="slot-panel-title">Character Filters — toggle ✓ include / ✕ exclude per slot</div>
    {% for i in range(1, 5) %}
    <div class="slot">
      <div class="slot-input-row">
        <input type="text" id="slotInput{{ i }}" class="slot-input" list="charList" placeholder="Character {{ i }}" data-slot="{{ i }}"/>
        <button class="slot-mode-btn mode-include" id="slotMode{{ i }}" data-slot="{{ i }}" title="Click to toggle include/exclude">✓</button>
      </div>
    </div>
    {% endfor %}
    <button class="slot-clear-all" id="slotClearAll">Clear all</button>
  </div>
  <datalist id="charList"></datalist>

  <div class="results-info" id="resultsInfo">Loading…</div>

  <div class="table-wrap">
    <div class="table-scroll">
      <table id="mainTable">
        <thead>
          <tr>
            <th data-col="Rank" class="num">#</th>
            <th data-col="dim_key">{{ dim_label }}</th>
            <th data-col="eid_range_key">Eid. Range</th>
            <th data-col="Team">Team</th>
            <th data-col="Appearance_Rate_pct" class="num sorted">App. Rate %</th>
            <th data-col="Samples" class="num">Samples</th>
            <th data-col="Sustain">Sustain</th>
            <th data-col="Min_Score" class="num">Min</th>
            <th data-col="Percentile_25" class="num">P25</th>
            <th data-col="Median_Score" class="num">Median</th>
            <th data-col="Percentile_75" class="num">P75</th>
            <th data-col="Average_Score" class="num">Avg</th>
            <th data-col="Max_Score" class="num">Max</th>
            <th data-col="Std_Dev" class="num">σ</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>
  </div>

</div>
<script>
const RAW_DATA        = {{ data_json }};
const ICONS           = {{ icons_json }};
const DIM_FIELD       = '{{ dim_field }}';
const DIM_LABEL       = '{{ dim_label }}';
const DIM_GROUP_LABELS = {{ dim_group_labels_json }};

const ROW_H    = 46;
const OVERSCAN = 6;
const VIEWPORT_H = 600;

RAW_DATA.forEach(r => {
  r.dim_key       = r[DIM_FIELD];
  r.eid_range_key = `${r.at_eidolon_level}_${r.up_to_eidolon_level}`;
  r.Sustain       = r['Sustain?'] ?? r['Sustain'] ?? false;
  const members   = parseMembers(r.Team);
  r._members      = members;
  r._membersLower = members.map(m => m.toLowerCase());
  r._iconsHtml    = members.map(iconEl).join('');
  r._teamLower    = r.Team.toLowerCase();
});

const MAX_RATE = Math.max(...RAW_DATA.map(r => r.Appearance_Rate_pct));

const ALL_CHAR_NAMES = [...new Set(RAW_DATA.flatMap(r => r._members))].sort();

(function populateCharList() {
  const dl = document.getElementById('charList');
  const frag = document.createDocumentFragment();
  ALL_CHAR_NAMES.forEach(name => {
    const opt = document.createElement('option');
    opt.value = name;
    frag.appendChild(opt);
  });
  dl.appendChild(frag);
})();

const TOKEN_INDEX = new Map();
RAW_DATA.forEach((r, i) => {
  const tokens = r._teamLower.split(/[\s\(\),\/\+•&]+/).filter(t => t.length >= 2);
  new Set(tokens).forEach(tok => {
    if (!TOKEN_INDEX.has(tok)) TOKEN_INDEX.set(tok, []);
    TOKEN_INDEX.get(tok).push(i);
  });
});

// Multi-word search: split query into words, AND across words.
// "dan heng" -> needs a token containing "dan" AND a token containing "heng",
// so "Dan Heng • Imbibitor Lunae" matches even though it's two separate tokens.
function searchIndex(query) {
  const words = query.split(/\s+/).filter(Boolean);
  if (words.length === 0) return null;

  let resultSet = null;
  for (const word of words) {
    const wordHits = new Set();
    TOKEN_INDEX.forEach((indices, tok) => {
      if (tok.includes(word)) indices.forEach(i => wordHits.add(i));
    });
    resultSet = resultSet === null ? wordHits : new Set([...resultSet].filter(i => wordHits.has(i)));
    if (resultSet.size === 0) break;
  }
  return resultSet;
}

const activeDims   = new Set(RAW_DATA.map(r => r.dim_key));
const activeRanges = new Set([
  '0_0','0_1','0_2','0_6',
  '1_1','1_2','1_6',
  '2_2','2_6','6_6'
]);
let showSustain   = true;
let showNoSustain = true;
let searchTerm    = '';
let sortCol       = 'Appearance_Rate_pct';
let sortAsc       = false;

// Character slot filters: index 0-3 for slots 1-4. Each: { name, mode: 'include'|'exclude' } | null
const slotFilters = [null, null, null, null];

let filteredData = [];

function recompute() {
  let candidate;
  if (searchTerm.length >= 2) {
    const hits = searchIndex(searchTerm);
    candidate = hits ? [...hits].map(i => RAW_DATA[i]) : [];
  } else if (searchTerm.length === 1) {
    candidate = RAW_DATA.filter(r => r._teamLower.includes(searchTerm));
  } else {
    candidate = RAW_DATA;
  }

  candidate = candidate.filter(r =>
    activeDims.has(r.dim_key) &&
    activeRanges.has(r.eid_range_key) &&
    (r.Sustain ? showSustain : showNoSustain)
  );

  const activeSlots = slotFilters.filter(Boolean);
  if (activeSlots.length > 0) {
    candidate = candidate.filter(r => {
      for (const slot of activeSlots) {
        const present = r._membersLower.includes(slot.name.toLowerCase());
        if (slot.mode === 'include' && !present) return false;
        if (slot.mode === 'exclude' && present)  return false;
      }
      return true;
    });
  }

  filteredData = candidate;

  filteredData.sort((a, b) => {
    let av = a[sortCol], bv = b[sortCol];
    if (typeof av === 'string') av = av.toLowerCase();
    if (typeof bv === 'string') bv = bv.toLowerCase();
    if (av == null) return 1; if (bv == null) return -1;
    return sortAsc ? (av > bv ? 1 : -1) : (av < bv ? 1 : -1);
  });

  updateMeta();
  renderViewport();
}

function updateMeta() {
  document.getElementById('visibleCount').textContent = filteredData.length.toLocaleString();
  const ssum = filteredData.reduce((s,r) => s + r.Samples, 0);
  document.getElementById('visibleSamples').textContent = ssum > 9999 ? (ssum/1000).toFixed(0)+'K' : ssum.toLocaleString();
  document.getElementById('resultsInfo').innerHTML = `Showing <span>${filteredData.length}</span> teams`;
}

function parseMembers(team) {
  return team
    .replace(/^\(|\)$/g, '')
    .split(/\s*[,\/\+]\s*/)
    .map(s => s.trim())
    .filter(Boolean);
}

function iconEl(name) {
  let url = ICONS[name];
  if (!url) url = ICONS[name.replace(/\s+LV\.\d+$/, '').trim()];
  if (url) return `<img class="char-icon" src="${url}" alt="${name}" title="${name}" onerror="this.style.display='none'"/>`;
  return `<div class="char-icon-placeholder" title="${name}">${name.slice(0,2).toUpperCase()}</div>`;
}

function fmtPct(v)      { return v == null ? '—' : v.toFixed(2) + '%'; }
function fmtNum(v, d=2) { return v == null ? '—' : v.toFixed(d); }
function fmtInt(v)      { return v == null ? '—' : v.toLocaleString(); }
function eidLabel(at, upto) { return at === upto ? `E${at}` : `E${at}→${upto}`; }
function eidCls(at, upto)   { return `eid-range-badge at${at}${at === upto ? ' exact' : ''}`; }

function rowHTML(r) {
  const ratePct    = Math.min(100, (r.Appearance_Rate_pct / MAX_RATE) * 100);
  const at         = r.at_eidolon_level, upto = r.up_to_eidolon_level;
  const sustainHtml = r.Sustain
    ? `<span class="sustain-pill yes">Sustain</span>`
    : `<span class="sustain-pill no">No Sustain</span>`;
  return `<tr>
    <td class="rank-cell${r.Rank<=3?' top3':''}">${r.Rank}</td>
    <td><span class="dim-badge d${r.dim_key}">${r.dim_key}</span></td>
    <td><span class="${eidCls(at,upto)}">${eidLabel(at,upto)}</span></td>
    <td><div class="team-cell"><div class="team-icons">${r._iconsHtml}</div><span class="team-name" title="${r.Team}">${r.Team}</span></div></td>
    <td class="num"><div class="rate-bar-wrap"><div class="rate-bar-bg"><div class="rate-bar-fill" style="width:${ratePct.toFixed(1)}%"></div></div><span class="rate-val">${fmtPct(r.Appearance_Rate_pct)}</span></div></td>
    <td class="num"><span class="score-num samp">${fmtInt(r.Samples)}</span></td>
    <td>${sustainHtml}</td>
    <td class="num"><span class="score-num">${fmtNum(r.Min_Score,1)}</span></td>
    <td class="num"><span class="score-num">${fmtNum(r.Percentile_25,1)}</span></td>
    <td class="num"><span class="score-num median">${fmtNum(r.Median_Score,1)}</span></td>
    <td class="num"><span class="score-num">${fmtNum(r.Percentile_75,1)}</span></td>
    <td class="num"><span class="score-num avg">${fmtNum(r.Average_Score,2)}</span></td>
    <td class="num"><span class="score-num maxv">${fmtNum(r.Max_Score,1)}</span></td>
    <td class="num"><span class="score-num std">${fmtNum(r.Std_Dev,2)}</span></td>
  </tr>`;
}

(function setupVirtualScroll() {
  const tableScroll = document.querySelector('.table-scroll');
  tableScroll.style.maxHeight = VIEWPORT_H + 'px';
  tableScroll.style.overflowY = 'auto';
  tableScroll.addEventListener('scroll', () => renderViewport(), { passive: true });
})();

function renderViewport() {
  const tbody       = document.getElementById('tableBody');
  const tableScroll = document.querySelector('.table-scroll');

  if (filteredData.length === 0) {
    tbody.innerHTML = `<tr><td colspan="14"><div class="empty-state"><div class="icon">⚡</div><p>No teams match current filters</p></div></td></tr>`;
    return;
  }

  const scrollTop  = tableScroll.scrollTop;
  const startIdx   = Math.max(0, Math.floor(scrollTop / ROW_H) - OVERSCAN);
  const endIdx     = Math.min(filteredData.length, Math.ceil((scrollTop + VIEWPORT_H) / ROW_H) + OVERSCAN);
  const paddingTop    = startIdx * ROW_H;
  const paddingBottom = (filteredData.length - endIdx) * ROW_H;

  let html = '';
  if (paddingTop > 0) {
    html += `<tr style="height:${paddingTop}px"><td colspan="14" style="padding:0;border:none"></td></tr>`;
  }

  let lastDim = startIdx > 0 ? filteredData[startIdx - 1].dim_key : null;
  for (let i = startIdx; i < endIdx; i++) {
    const r = filteredData[i];
    if (r.dim_key !== lastDim) {
      const lbl = DIM_GROUP_LABELS[r.dim_key] || `${DIM_LABEL} ${r.dim_key}`;
      html += `<tr class="group-sep"><td colspan="14"><span class="group-label-${r.dim_key}">${lbl}</span></td></tr>`;
      lastDim = r.dim_key;
    }
    html += rowHTML(r);
  }

  if (paddingBottom > 0) {
    html += `<tr style="height:${paddingBottom}px"><td colspan="14" style="padding:0;border:none"></td></tr>`;
  }

  tbody.innerHTML = html;
}

function debounce(fn, ms) {
  let t;
  return (...args) => { clearTimeout(t); t = setTimeout(() => fn(...args), ms); };
}

document.querySelectorAll('#dimFilters .btn-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const d = parseInt(btn.dataset.dim);
    if (activeDims.has(d)) {
      if (activeDims.size > 1) { activeDims.delete(d); btn.classList.remove('active'); }
    } else { activeDims.add(d); btn.classList.add('active'); }
    document.querySelector('.table-scroll').scrollTop = 0;
    recompute();
  });
});

document.querySelectorAll('#eidFilters .btn-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const key = `${btn.dataset.at}_${btn.dataset.upto}`;
    if (activeRanges.has(key)) {
      if (activeRanges.size > 1) { activeRanges.delete(key); btn.classList.remove('active'); }
    } else { activeRanges.add(key); btn.classList.add('active'); }
    document.querySelector('.table-scroll').scrollTop = 0;
    recompute();
  });
});

document.getElementById('btnSustainOn').addEventListener('click', () => {
  if (showSustain && !showNoSustain) return;
  showSustain = !showSustain;
  document.getElementById('btnSustainOn').classList.toggle('active', showSustain);
  document.querySelector('.table-scroll').scrollTop = 0;
  recompute();
});
document.getElementById('btnSustainOff').addEventListener('click', () => {
  if (!showSustain && showNoSustain) return;
  showNoSustain = !showNoSustain;
  document.getElementById('btnSustainOff').classList.toggle('active', showNoSustain);
  document.querySelector('.table-scroll').scrollTop = 0;
  recompute();
});

// Free-text search — debounced, multi-word AND across tokens.
// Fixes "Dan Heng" type queries previously broken by spacing.
document.getElementById('searchInput').addEventListener('input', debounce(e => {
  searchTerm = e.target.value.trim().toLowerCase();
  document.querySelector('.table-scroll').scrollTop = 0;
  recompute();
}, 200));

// ---- Character slot filters ----

function updateSlotFromInput(slotIdx) {
  const input   = document.getElementById(`slotInput${slotIdx + 1}`);
  const modeBtn = document.getElementById(`slotMode${slotIdx + 1}`);
  const val = input.value.trim();

  if (val === '') {
    slotFilters[slotIdx] = null;
    input.classList.remove('slot-filled', 'slot-exclude');
    return;
  }

  const exact = ALL_CHAR_NAMES.find(n => n.toLowerCase() === val.toLowerCase());
  const name = exact || val;

  const mode = modeBtn.classList.contains('mode-exclude') ? 'exclude' : 'include';
  slotFilters[slotIdx] = { name, mode };

  input.classList.add('slot-filled');
  input.classList.toggle('slot-exclude', mode === 'exclude');
}

for (let i = 0; i < 4; i++) {
  const input   = document.getElementById(`slotInput${i + 1}`);
  const modeBtn = document.getElementById(`slotMode${i + 1}`);

  input.addEventListener('input', debounce(() => {
    updateSlotFromInput(i);
    document.querySelector('.table-scroll').scrollTop = 0;
    recompute();
  }, 200));

  modeBtn.addEventListener('click', () => {
    const isExclude = modeBtn.classList.toggle('mode-exclude');
    modeBtn.classList.toggle('mode-include', !isExclude);
    modeBtn.textContent = isExclude ? '✕' : '✓';
    modeBtn.title = isExclude
      ? 'Excluding this character — click to switch to include'
      : 'Including this character — click to switch to exclude';
    updateSlotFromInput(i);
    document.querySelector('.table-scroll').scrollTop = 0;
    recompute();
  });
}

document.getElementById('slotClearAll').addEventListener('click', () => {
  for (let i = 0; i < 4; i++) {
    const input   = document.getElementById(`slotInput${i + 1}`);
    const modeBtn = document.getElementById(`slotMode${i + 1}`);
    input.value = '';
    input.classList.remove('slot-filled', 'slot-exclude');
    modeBtn.classList.remove('mode-exclude');
    modeBtn.classList.add('mode-include');
    modeBtn.textContent = '✓';
    modeBtn.title = 'Click to toggle include/exclude';
    slotFilters[i] = null;
  }
  document.querySelector('.table-scroll').scrollTop = 0;
  recompute();
});

document.querySelectorAll('th[data-col]').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    if (sortCol === col) sortAsc = !sortAsc;
    else { sortCol = col; sortAsc = false; }
    document.querySelectorAll('th').forEach(t => t.classList.remove('sorted','asc'));
    th.classList.add('sorted');
    if (sortAsc) th.classList.add('asc');
    document.querySelector('.table-scroll').scrollTop = 0;
    recompute();
  });
});

recompute();
</script>
</body>
</html>